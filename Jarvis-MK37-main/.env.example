CEREBRAS_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
INTELX_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
VENICE_API_KEY=
KINDO_API_KEY=
HACKERGPT_API_KEY=

# System Configuration
OS_SYSTEM=windows
OLLAMA_BASE_URL=http://localhost:11434
